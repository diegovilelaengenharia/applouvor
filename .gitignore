# ======================================
# App Louvor - .gitignore
# ======================================

# Dependências
/vendor/
/node_modules/

# Arquivos de configuração sensíveis
# IMPORTANTE: .htaccess contém credenciais do banco (SetEnv DB_PASS)
.htaccess
.env
composer.lock

# Arquivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
error_log

# Uploads de usuários (opcional - descomente se não quiser versionar)
# assets/uploads/

# Arquivos temporários
*.tmp
*.bak
*.cache

# Versao antiga (backup local — nao versionar)
App louvor 23.01.2026/

# Credenciais de ambiente (NUNCA versionar)
.env.*
!.env.example
.env.backup

# Chaves privadas (VAPID, JWT, etc.)
includes/vapid_config.php
includes/*_secret.php

# Backups e dumps
*.backup
*.dump
*.sql.gz
