# ======================================
# App Louvor - .gitignore
# ======================================

# Dependências
/vendor/
/node_modules/

# Arquivos de configuração sensíveis
# Diego: .htaccess versionado intencionalmente para o webhook deployar (decisão explícita).
# Senha de DB em plain text — não compartilhar repositório publicamente sem rotacionar antes.
.env
composer.lock

# Arquivos de sistema
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
error_log

# Uploads de usuários (opcional - descomente se não quiser versionar)
# assets/uploads/

# Arquivos temporários
*.tmp
*.bak
*.cache

# Versao antiga (backup local — nao versionar)
App louvor 23.01.2026/
app louvor arquivos hostinger atual/
app antigo/

# Credenciais de ambiente (NUNCA versionar)
.env.*
!.env.example
.env.backup

# Chaves privadas (VAPID, JWT, etc.)
includes/vapid_config.php
includes/*_secret.php

# Backups e dumps
*.backup
*.dump
*.sql.gz

# Backups locais e pastas temporárias pesadas
site todo/
site todo/**
