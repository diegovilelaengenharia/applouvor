# .htaccess — App Louvor (site público)
# FASE 01: regras de segurança (herdadas da FASE 00) + rewrite do front controller.

Options -Indexes
ServerSignature Off

# Nunca servir arquivos sensíveis, mesmo que alguém os suba por engano.
# Sintaxe Apache 2.4 (Require) com fallback 2.2 (Order/Deny) via <IfModule>, para não
# depender de qual MPM/mod_access está ativo no host.
<FilesMatch "\.(env|sql|log|bak|backup|dump)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# PHP/HTML: nunca cachear (conteúdo dinâmico).
<FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</FilesMatch>

# Front controller: só reescreve para router.php quando o pedido NÃO é um arquivo/pasta real
# (deixa diag.php, assets, etc. serem servidos diretamente).
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ router.php?route=$1 [QSA,L]
