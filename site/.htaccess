# .htaccess — App Louvor (site público)
# FASE 00: só regras de segurança básica. Sem front controller/MVC ainda (isso volta na
# FASE 01, junto com o esqueleto de produto).

Options -Indexes
ServerSignature Off

# Nunca servir arquivos sensíveis, mesmo que alguém os suba por engano.
# Sintaxe Apache 2.4 (Require) com fallback 2.2 (Order/Deny) via <IfModule>, para não
# depender de qual MPM/mod_access está ativo no host.
<FilesMatch "\.(env|sql|log|bak|backup|dump)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# PHP/HTML: nunca cachear (conteúdo dinâmico).
<FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</FilesMatch>
